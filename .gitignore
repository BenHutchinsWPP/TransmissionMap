# Personal IDE / workspace config
Workspace.code-workspace

# Intermediate tile-building files (large, regenerable)
*.geojsonl
*.geojson.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# OSM source data (large downloads — place in data/raw/osm/)
data/raw/osm/*.osm.pbf
data/raw/osm/*.pbf
data/raw/osm/*.o5m

# Reference data (auto-downloaded by extraction scripts on first run)
data/raw/hifld/
data/raw/eia/
data/raw/eia_petroleum/

# Mines source data (MSHA zips, manual download — see extract_mines.py)
data/raw/mines/

# Seismic hazard source (USGS NSHM 2018 CSV grid, 37 MB — see build_seismic_hazard.sh)
data/raw/usgs/

# Land-constraint source data (manual placement — large; see merge_land_constraints.py)
data/raw/padus/
data/raw/aiannh/
data/raw/crithab/
data/raw/ogf/

# Wind resource source zips (~540 MB — recovered from Internet Archive; see
# docs/data-sources.md for the Wayback URLs and build_wind_resource.sh)
data/raw/wind/

# Solar resource source zip (~345 MB — Global Solar Atlas PVOUT; re-fetch via
# build_solar_resource.sh, which downloads it automatically)
data/raw/solar/

# Geothermal resource source zip (~18 MB — IHFC 2024 heat flow; re-fetch via
# build_geothermal_resource.sh, which downloads it automatically)
data/raw/geothermal/

# Hydrothermal systems source zip (~952 KB — NREL/DOE GDR; re-fetch via
# build_hydrothermal_pts.sh, which downloads it automatically)
data/raw/hydrothermal/

# Population density GeoTIFFs (~170 MB — WorldPop 2020 USA/CAN/MEX; re-fetch via
# build_population_density.sh, which downloads them automatically)
data/raw/population/

# USFS Wildfire Hazard Potential (RDS-2015-0047-4 zips + extracted GeoTIFFs/gdb;
# see docs/layers/wildfire-hazard.md. Tiles built by build_wildfire_hazard.sh)
data/raw/wildfire_hazard/

# Railroads source GeoJSON (~345 MB — BTS NARN; re-fetch from geodata.bts.gov;
# see docs/layers/railroads.md. Tiles built by build_railroads().)
data/raw/railroads/

# FEMA National Risk Index source (GDB zip ~112 MB + extracted .gdb + PDF;
# see docs/layers/nri-hazards.md. Tiles built by extract_nri.py + build_tiles.py)
data/raw/fema/

# NOAA / ASCE 7-22 design-wind contours (manual GeoJSON download from the NOAA
# ASCE Wind Vectors hub; see docs/layers/design-wind.md). Tiles built by build_tiles.py.
data/raw/noaa/

# County boundaries source zip (~12 MB — Census TIGER cartographic
# cb_2024_us_county_500k; re-fetch via build_boundaries.sh, which downloads it
# automatically)
# IM3 US Data Center Locations GeoPackage (~843 KB; auto-downloaded by extract_osm_datacenters.py)
data/raw/im3/

# BIA AIAN-LAR GeoJSON (auto-downloaded by extract_bia_tribal.py; see docs/layers/bia-tribal-lands.md)
data/raw/bia/
data/raw/boundaries/

# >>> ADD-LAYER: gitignore — new layer's raw source dir goes ABOVE this line.
# data/raw/<source>/ is NOT ignored by default; `git add -A` will otherwise
# commit the (often large) raw download. Built tiles in data/layers/ are
# gitignored too — they ship via `make publish-data` → orphan 'data-static' branch.

# Gitignore the generated load layer artifacts (raw .geojson pre-gzip; only .geojson.gz ships)
data/load/*.geojson
# data/load/*.pmtiles
# data/load/*.i16
# data/load/*.json

# GDAL stats/aux sidecars
*.aux.xml

# Pipeline output + intermediates (generated by `make pipeline` — not committed)
data/build/

# Build artefacts that don't belong in the repo
data/downloads/shp/

# Layers that link out to stable sources — no ZIP produced.
data/downloads/padus.zip
data/downloads/padus-protected-lands.zip
data/downloads/tribal-lands.zip
data/downloads/gsa-solar-pvout.zip

# Built layer files and release ZIPs — published to the orphan 'data-static'
# branch via `make publish-data` (served from raw.githubusercontent.com); not tracked in repo.
data/layers/
data/releases/

# Raw served GeoJSON — shipped pre-gzipped as .geojson.gz instead.
# (build_tiles.sh runs gzip_served_geojson; the app decompresses client-side.)
# These globs ignore *.geojson but NOT *.geojson.gz, which is what ships.
data/substations/*.geojson
data/generators/*.geojson
data/pipelines/*.geojson

# Dead pmtiles — these layers are served as gzipped GeoJSON, not vector tiles
data/substations/*.pmtiles
data/pipelines/osm_pipelines_points.pmtiles

# PMTiles sqlite read-journal sidecars (created when a tool opens a .pmtiles)
*.pmtiles-journal

# Local scratch / temp downloads
tmp/

# Node
node_modules/
dist/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Test coverage reports
coverage/
