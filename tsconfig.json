{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "paths": {},
    "skipLibCheck": true
  },
  "include": ["src/**/*", "assets/**/*"],
  "exclude": ["node_modules", "dist", "venv"]
}
